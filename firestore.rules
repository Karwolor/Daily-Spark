rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users (including anonymous) to read/write their own user document and all subcollections
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to access their top-level user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // For development/testing: Allow all authenticated reads/writes (remove in production)
    // This helps diagnose permission issues
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}